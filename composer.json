{
    "name": "yolorouter/llmasking-php",
    "description": "LLM-oriented PII masking and restoration library (PHP port of llmasking-go).",
    "license": "MIT",
    "type": "library",
    "require": {
        "php": "^8.1",
        "ext-hash": "*",
        "ext-json": "*",
        "ext-mbstring": "*",
        "ext-pcre": "*",
        "ext-zlib": "*",
        "wikimedia/aho-corasick": "2.0.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "phpstan/phpstan": "^1.11",
        "friendsofphp/php-cs-fixer": "^3.59"
    },
    "autoload": {
        "psr-4": { "Yolorouter\\Llmasking\\": "src/" }
    },
    "autoload-dev": {
        "psr-4": { "Yolorouter\\Llmasking\\Tests\\": "tests/" }
    },
    "scripts": {
        "test": "phpunit",
        "analyse": "phpstan analyse",
        "format-check": "php-cs-fixer check --verbose",
        "format-fix": "php-cs-fixer fix"
    },
    "config": { "sort-packages": true }
}
